    {
      "name": "ERROS — Autorização",
      "description": "Cenários negativos de autenticação e autorização.",
      "item": [

        {
          "name": "T18 — Perfil CLIENTE tenta registrar entrada de estoque (negativo — 403)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 403', () => pm.response.to.have.status(403));",
                "pm.test('Erro SEM_PERMISSAO', () => {",
                "  const json = pm.response.json();",
                "  pm.expect(json.error).to.eql('SEM_PERMISSAO');",
                "  pm.expect(json).to.have.all.keys('error','message','details','timestamp','path');",
                "});"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenCliente}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/unidades/1/estoque/1/entrada",
              "host": ["{{baseUrl}}"],
              "path": ["unidades","1","estoque","1","entrada"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantidade\": 10,\n  \"motivo\": \"Tentativa não autorizada\"\n}"
            }
          }
        },

        {
          "name": "T19 — Pedido com unidade inexistente (negativo — 404)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 404', () => pm.response.to.have.status(404));",
                "pm.test('Erro RECURSO_NAO_ENCONTRADO', () => {",
                "  const json = pm.response.json();",
                "  pm.expect(json.error).to.eql('RECURSO_NAO_ENCONTRADO');",
                "});"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenCliente}}" }
            ],
            "url": { "raw": "{{baseUrl}}/pedidos", "host": ["{{baseUrl}}"], "path": ["pedidos"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unidadeId\": 99999,\n  \"clienteId\": 1,\n  \"canalPedido\": \"APP\",\n  \"formaPagamento\": \"MOCK\",\n  \"itens\": [\n    { \"itemId\": 1, \"variacaoId\": 2, \"quantidade\": 1 }\n  ]\n}"
            }
          }
        },

        {
          "name": "T20 — Transição de status inválida (negativo — 409)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 409', () => pm.response.to.have.status(409));",
                "pm.test('Erro TRANSICAO_STATUS_INVALIDA', () => {",
                "  const json = pm.response.json();",
                "  pm.expect(json.error).to.eql('TRANSICAO_STATUS_INVALIDA');",
                "  pm.expect(json.details[0].field).to.eql('status');",
                "});"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenCozinha}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/pedidos/{{pedidoId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["pedidos","{{pedidoId}}","status"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"EM_PREPARO\",\n  \"motivo\": \"Tentativa de retroceder status já finalizado\"\n}"
            }
          }
        }

      ]
    }

