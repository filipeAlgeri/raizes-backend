# =============================================================
# .env.example — Raízes do Nordeste
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env no repositório
# =============================================================

# Banco de dados PostgreSQL
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL="postgresql://postgres:suasenha@localhost:5432/raizes_db"

# Servidor
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET="troque_por_uma_chave_segura_e_longa"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# Pagamento mock
# "always_approve" | "always_reject" | "random"
PAYMENT_MOCK_MODE="random"

# LGPD — retenção de dados (em dias)
DATA_RETENTION_DAYS=365
